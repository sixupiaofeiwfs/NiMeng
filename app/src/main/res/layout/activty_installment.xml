<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/turntable_linearLayout1"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="150dp"
            android:layout_height="75dp"
            android:layout_marginTop="90dp"
            android:gravity="center"
            android:text="总期数" />

        <Spinner
            android:id="@+id/spinner2"
            android:layout_width="150dp"
            android:layout_height="75dp"
            android:layout_marginTop="90dp"
            android:entries="@array/data2"
            android:spinnerMode="dropdown" />


        <TextView
            android:layout_width="150dp"
            android:layout_height="75dp"
            android:layout_marginTop="90dp"
            android:gravity="center"
            android:text="超级密码" />


        <EditText
            android:id="@+id/miao4"
            android:layout_width="150dp"
            android:layout_height="75dp"
            android:layout_marginTop="90dp"
            android:inputType="text" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/turntable_linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/turntable_linearLayout1"
        android:layout_marginTop="27dp"
        android:orientation="horizontal">


        <Button
            android:id="@+id/btn_true"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:layout_marginRight="600dp"
            android:text="保存" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/turntable_linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_below="@id/turntable_linearLayout2"
        android:layout_marginTop="0dp"
        android:orientation="horizontal">


        <TextView
            android:id="@+id/list_templan_name"
            android:layout_width="21dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:gravity="center"
            android:paddingTop="10dip"
            android:paddingBottom="10dip"
            android:singleLine="true"
            android:text="期数"
            android:textColor="#000000"
            android:textSize="15sp" />

        <View
            android:layout_width="1.5dip"
            android:layout_height="fill_parent"
            android:background="#B4B3B3" />

        <TextView
            android:id="@+id/list_templan_unitTime"
            android:layout_width="76dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:paddingTop="10dip"
            android:paddingBottom="10dip"
            android:singleLine="true"
            android:text="密码"
            android:textColor="#000000"
            android:textSize="15sp" />

        <View
            android:layout_width="1.5dip"
            android:layout_height="fill_parent"
            android:background="#B4B3B3" />


        <TextView
            android:id="@+id/list_templan_temWave"
            android:layout_width="189dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingTop="10dip"
            android:paddingBottom="10dip"
            android:singleLine="true"
            android:text="到期时间"
            android:textColor="#000000"
            android:textSize="15sp" />

        <View
            android:layout_width="1.5dip"
            android:layout_height="fill_parent"
            android:background="#B4B3B3" />


    </LinearLayout>

</RelativeLayout>